# ─────────────────────────────────────────────
#  ENARMAGIC — Variables de entorno
#  Copia este archivo como .env y llena los valores REALES
#  NUNCA subas el archivo .env a GitHub
# ─────────────────────────────────────────────

# Puerto del servidor (Railway lo asigna automáticamente)
PORT=3000

# URL base de la aplicación (cambia a tu dominio de Railway en producción)
BASE_URL=https://TU-APP.up.railway.app

# ── Google OAuth ──────────────────────────────
# Obtén estas credenciales en: https://console.cloud.google.com
GOOGLE_CLIENT_ID=tu_google_client_id_aqui
GOOGLE_CLIENT_SECRET=tu_google_client_secret_aqui

# ── Stripe ────────────────────────────────────
# Obtén estas claves en: https://dashboard.stripe.com/apikeys
# Usa las claves sk_test_... / pk_test_... para pruebas
# Usa las claves sk_live_... / pk_live_... para producción REAL
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── Sesión ────────────────────────────────────
# Genera un string largo y aleatorio (mínimo 32 caracteres)
SESSION_SECRET=cambia_esto_por_un_string_muy_largo_y_aleatorio_aqui
